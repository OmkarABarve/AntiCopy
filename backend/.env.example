# Backend configuration (copy to .env and adjust). All values are optional.

# Comma-separated list of allowed CORS origins for the dashboard.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# How often (seconds) the backend recomputes + broadcasts a state snapshot.
BROADCAST_INTERVAL_S=0.75

# Rolling window (seconds) for rolling features such as rolling WPM.
ROLLING_WINDOW_S=30

# --- Optional upgrade paths (off by default) ---
# Enable server-side streaming ASR via WhisperLive (see app/whisperlive.py).
ENABLE_WHISPERLIVE=false
WHISPERLIVE_HOST=localhost
WHISPERLIVE_PORT=9090

# Enable a trained ML model (XGBoost/sklearn) in the risk engine.
ENABLE_ML_MODEL=false
